{
  "name": "numscript-agent-city",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "run-template": "pnpm --filter @nac/cli run-template",
    "city:start": "pnpm --filter @nac/orchestrator run-city",
    "city:watch": "pnpm --filter @nac/orchestrator watch-events",
    "city:tick": "pnpm --filter @nac/orchestrator run-agent-once",
    "seed-genesis": "tsx scripts/seed-genesis.ts",
    "validate-templates": "tsx scripts/validate-templates.ts",
    "ledger:up": "docker compose up -d && ./scripts/wait-for-ledger.sh",
    "ledger:down": "docker compose down -v"
  },
  "dependencies": {
    "@nac/template-engine": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
