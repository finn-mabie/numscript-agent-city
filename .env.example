# ── Local dev (default) ─────────────────────────────────────────────
LEDGER_URL=http://localhost:3068
LEDGER_NAME=city
GENESIS_POOL=USD/2 1000000

# ── Remote Formance Cloud (uncomment + fill if targeting a hosted stack) ──
# LEDGER_URL includes the /api/ledger prefix for cloud stacks. The client
# appends /v2/{ledger}/... itself.
# LEDGER_URL=https://<stack-id>.console.demo.dev.formance.cloud/api/ledger
# LEDGER_NAME=city
# OAUTH_TOKEN_ENDPOINT=https://<stack-id>.console.demo.dev.formance.cloud/api/auth/oauth/token
# OAUTH_CLIENT_ID=demo-portal
# OAUTH_CLIENT_SECRET=demo-portal-secret-2026

# ── Orchestrator (Plan 2) ─────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: path for the agent-state SQLite file (default: data/orchestrator.sqlite)
# NAC_DB=./data/orchestrator.sqlite
# WebSocket port for the event bus (default: 3070)
# CITY_WS_PORT=3070
# CITY_WS_URL=ws://127.0.0.1:3070   # used by watch-events CLI

# Faster tick interval for visualization demos (20-40s instead of 7-13min).
# DEMO_MODE=1
# TICK_MIN_MS=20000
# TICK_MAX_MS=40000
# HTTP /snapshot port (default 3071)
# CITY_HTTP_PORT=3071
