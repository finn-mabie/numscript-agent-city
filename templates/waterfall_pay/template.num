vars {
  monetary $amount
  account  $agent_credits
  account  $agent_earnings
  account  $agent_main
  account  $to
  string   $memo
}

send $amount (
  source      = {
    $agent_credits
    $agent_earnings
    $agent_main
  }
  destination = $to
)

set_tx_meta("type", "WATERFALL_PAY")
set_tx_meta("memo", $memo)
