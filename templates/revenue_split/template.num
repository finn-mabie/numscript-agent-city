vars {
  monetary $total
  account  $pool
  account  $recipient_a
  portion  $share_a
  account  $recipient_b
  portion  $share_b
  account  $recipient_c
  string   $round_ref
}

send $total (
  source      = $pool
  destination = {
    $share_a  to $recipient_a
    $share_b  to $recipient_b
    remaining to $recipient_c
  }
)

set_tx_meta("type",      "REVENUE_SPLIT")
set_tx_meta("round_ref", $round_ref)
