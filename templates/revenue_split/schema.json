{
  "id": "revenue_split",
  "description": "Distribute a pool balance to three recipients by declared shares. Atomic 3-posting split.",
  "params": {
    "total":       { "type": "monetary", "asset": "USD/2", "max": "100000_00", "min": "1" },
    "pool":        { "type": "account",  "pattern": "^@platform:pool:[a-zA-Z0-9-]+$" },
    "recipient_a": { "type": "account",  "pattern": "^@agents:[0-9]+:available$" },
    "share_a":     { "type": "portion",  "max": "100%" },
    "recipient_b": { "type": "account",  "pattern": "^@agents:[0-9]+:available$" },
    "share_b":     { "type": "portion",  "max": "100%" },
    "recipient_c": { "type": "account",  "pattern": "^@agents:[0-9]+:available$" },
    "round_ref":   { "type": "string",   "maxLength": 64 }
  }
}
